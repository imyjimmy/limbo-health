PUBLIC_HOSTNAME=limbo.health
PUBLIC_BASE_URL=https://limbo.health

LIMBO_DATA_DIR=/srv/limbo-data
AWS_REGION=us-east-1

DB_NAME=limbo_health
DB_USER=limbo_app
DB_PASSWORD=replace-me
MYSQL_ROOT_PASSWORD=replace-me

RECORDS_WORKFLOW_DB_NAME=records_workflow
RECORDS_WORKFLOW_DB_USER=postgres
RECORDS_WORKFLOW_DB_PASSWORD=replace-me

JWT_SECRET=replace-me
INTERNAL_API_SECRET=replace-me
NOSTR_RELAYS=wss://relay.damus.io,wss://relay.primal.net

GOOGLE_CLIENT_ID=replace-me
GOOGLE_CLIENT_SECRET=replace-me
GOOGLE_REDIRECT_URI=https://limbo.health/api/google/login/callback
GOOGLE_REDIRECT_URI_ADMIN=https://limbo.health

# Optional for billing/payment flows only.
ALBY_CLIENT_ID=
ALBY_CLIENT_SECRET=
NWC_CONNECTION_STRING=
ADMIN_NOSTR_PRIVATE_KEY=

# Optional until you enable the backup scripts.
BACKUP_S3_BUCKET=

STAGING_CLEANUP_INTERVAL_MS=900000
