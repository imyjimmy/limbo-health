{
  "name": "records-workflow-api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "State-aware medical-records workflow crawler and read API",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "migrate": "node src/migrate.js",
    "seed": "node src/seed.js",
    "crawl": "node src/crawl.js",
    "generate:reasonable-seeds": "node src/generateReasonableSeeds.js",
    "build:national-roster": "node src/buildNationalHospitalRoster.js",
    "report:national-roster-coverage": "node src/reportNationalRosterCoverage.js",
    "generate:seed-candidates": "node src/generateSeedCandidates.js",
    "import:generated-seeds": "node src/importGeneratedSeeds.js",
    "crawl:rollout": "node src/crawlRollout.js",
    "crawl:rollout:incremental": "node src/crawlRolloutIncremental.js",
    "backfill:pdf-form-understanding": "node src/backfillPdfFormUnderstanding.js",
    "audit:pdf-form-understanding": "node src/auditPdfFormUnderstanding.js",
    "repair:pdf-names": "node src/repairPdfNames.js",
    "reset:crawl-state": "node src/resetCrawlState.js",
    "repartition:raw-storage-state": "node src/repartitionRawStorageByState.js",
    "cleanup:stale-crawl": "node src/cleanupStaleCrawlData.js --apply",
    "cleanup:stale-crawl:dry-run": "node src/cleanupStaleCrawlData.js",
    "test": "node --test --experimental-test-module-mocks"
  },
  "dependencies": {
    "cheerio": "^1.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^5.1.0",
    "pdf-parse": "^1.1.1",
    "pg": "^8.16.3"
  }
}
